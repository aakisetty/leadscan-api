# LeadScan AI — Environment Variables
# Copy this to .env for local development. NEVER commit .env to git.

# ── Google APIs ───────────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=AIzaSy...           # Places API (New) — console.cloud.google.com
PAGESPEED_API_KEY=AIzaSy...               # PageSpeed Insights API — same project or separate key

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...              # console.anthropic.com

# ── GoHighLevel ───────────────────────────────────────────────────────────────
GHL_API_KEY=...                           # GHL → Settings → Business Profile → API Key
GHL_LOCATION_ID=...                       # GHL → Settings → Business Info (or URL)
GHL_PIPELINE_ID=...                       # GHL → Opportunities → Pipelines → LeadScan AI
GHL_STAGE_NO_WEBSITE=...                  # Stage: "No website — highest priority"
GHL_STAGE_WEBSITE_NO_ADS=...              # Stage: "Website only — ads opportunity"
GHL_STAGE_NEEDS_GBP_ADS=...              # Stage: "Needs GBP + Google Ads"
GHL_STAGE_NURTURE=...                     # Stage: "Nurture — monitor only"
GHL_WORKFLOW_ID=                          # Optional: outreach workflow ID

# ── Pipeline tuning ───────────────────────────────────────────────────────────
AUDIT_DELAY_S=1.5                         # Seconds between auditing each business
REGION_CODE=AU                            # Two-letter region code
